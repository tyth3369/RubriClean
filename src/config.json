{
  "_comment": "RubriClean v2.1 配置文件 — Standard / Deep / Bridge 共用可调参数",
  "_note": "HSV 范围格式为 [H, S, V]，OpenCV H: 0-180, S: 0-255, V: 0-255",

  "hsv": {
    "red1_lower": [0, 50, 50],
    "red1_upper": [10, 255, 255],
    "red2_lower": [170, 50, 50],
    "red2_upper": [180, 255, 255]
  },

  "rgb_diff": {
    "threshold": 20,
    "r_min": 50
  },

  "local_contrast": {
    "r_advantage": 5,
    "r_min": 30,
    "proximity": 5
  },

  "morphology": {
    "close_kernel": 5,
    "open_kernel": 3,
    "gap_close_kernel": 7
  },

  "stroke_expand": {
    "dilate_iter": 3,
    "dilate_kernel": 5
  },

  "safety": {
    "gray_tolerance": 5
  },

  "fringe_absorption": {
    "_comment": "Light-gated 晕影吸收 — 清除红笔周围浅色扫描过渡带",
    "dilate_px": 13,
    "light_thresh": 200
  },

  "channel_balance": {
    "_comment": "通道均衡填充 — 上下文感知，红黑交叉处保留暗色笔画",
    "ink_gray_thresh": 80,
    "ink_redness_max": 10,
    "ink_dilate_px": 3,
    "ink_min_area": 15
  },

  "inpainting": {
    "radius": 5,
    "method": "telea"
  },

  "output": {
    "suffix": "_clean",
    "format": "jpg",
    "quality": 95,
    "skip_if_no_red": true
  },

  "border_removal": {
    "border_width": 20,
    "darkness_threshold": 40
  }
}
